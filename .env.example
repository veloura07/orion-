# ── NEXUS Safe Web MVP — Environment Variables ──
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required for real Gemini responses.
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — override default Gemini model for each mode.
# Default fast:     gemini-2.0-flash-lite
# Default balanced: gemini-2.0-flash
# Default deep:     gemini-2.5-pro-preview-05-06
# NEXUS_MODEL_FAST=gemini-2.0-flash-lite
# NEXUS_MODEL_BALANCED=gemini-2.0-flash
# NEXUS_MODEL_DEEP=gemini-2.5-pro-preview-05-06

# Server settings (defaults shown)
# PORT=3001
# CORS_ORIGIN=http://localhost:5173
